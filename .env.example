# Aether Environment Configuration
# Copy this file to .env and fill in your values

# Database - Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your-password@your-neon-host-pooler.neon.tech/neondb?sslmode=require

# Application
SECRET_KEY=your-super-secret-key-change-in-production
ENV=development
DEBUG=true

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: Neon-specific parameters (auto-removed by clean_url())
# NEON_POOL_PARAMETERS=pool_timeout=10
