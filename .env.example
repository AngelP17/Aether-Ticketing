# Aether Environment Configuration
# Copy this file to .env and fill in your values

# Database - Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your-password@your-neon-host-pooler.neon.tech/neondb?sslmode=require

# Application
SECRET_KEY=your-super-secret-key-change-in-production
ENV=development
DEBUG=true

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: Neon-specific parameters (auto-removed by clean_url())
# NEON_POOL_PARAMETERS=pool_timeout=10

# Phase 8 Competitor Parity (email, WS, webhooks, etc.)
# SMTP for outbound notifications (email on decisions, applies, SLA). Use real creds only in prod.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASSWORD=...
SMTP_FROM=aether@ops.local
SMTP_USE_TLS=true

# Inbound email (IMAP stub for ticket creation from mail; parser in email_service)
# IMAP_HOST=imap.example.com
# IMAP_USER=...
# IMAP_PASSWORD=...
IMAP_MAILBOX=INBOX

# WS realtime enabled (server + client pub/sub)
WS_ENABLED=true

# Webhook signing/timeout
WEBHOOK_TIMEOUT_SEC=10
